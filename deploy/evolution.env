# Webhook (desabilitado - será definido por instância)
WEBHOOK_GLOBAL_ENABLED=false

# WhatsApp Session
CONFIG_SESSION_PHONE_CLIENT=MARKELLO
CONFIG_SESSION_PHONE_NAME=markello-crm
CONFIG_SESSION_PHONE_VERSION=
QRCODE_LIMIT=30

# CORS
CORS_ORIGIN=*
CORS_METHODS=GET,POST,PUT,PATCH,DELETE
CORS_CREDENTIALS=true

# Logging
LOG_LEVEL=ERROR,WARN,INFO,LOG
LOG_COLOR=true

